---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Path for the canonical URL, e.g. "/" or "/faq" */
  path: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  /** Structured data object(s) rendered as JSON-LD in <head> */
  jsonLd?: object;
}

const { title, description, path, ogTitle, ogDescription, ogType = 'website', jsonLd } = Astro.props;
const canonical = new URL(path, Astro.site).href;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="icon" type="image/png" sizes="1001x1001" href="/icon.png">
<link rel="apple-touch-icon" href="/icon.png">
<meta property="og:image" content="https://localai.nz/og-image.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:type" content={ogType}>
<meta property="og:title" content={ogTitle ?? title}>
<meta property="og:description" content={ogDescription ?? description}>
<meta property="og:url" content={canonical}>
<meta property="og:locale" content="en_NZ">
<meta name="robots" content="index, follow">
<link rel="sitemap" href="/sitemap-index.xml">
<link rel="alternate" type="application/rss+xml" title="Local AI — Notes" href="/rss.xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
</head>
<body id="top">
<slot />
</body>
</html>
