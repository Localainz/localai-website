<script>
  // "Why now" viz: draws once each time it scrolls into view, holds at the end.
  (function () {
    var host = document.getElementById('why-viz');
    if (!host) return;
    var W = 440, H = 190;
    var padL = 8, padR = 64, padT = 26, padB = 30;
    var x0 = padL, x1 = W - padR, yBase = H - padB, yTop = padT;
    var NS = 'http://www.w3.org/2000/svg';
    function el(tag: string, attrs: Record<string, string | number>) {
      var e = document.createElementNS(NS, tag);
      for (var k in attrs) e.setAttribute(k, String(attrs[k]));
      return e;
    }
    var svg = el('svg', { viewBox: '0 0 ' + W + ' ' + H });
    // y position of each curve at progress t (0..1)
    function yAI(t: number) { return yBase - (yBase - yTop) * (Math.pow(t, 1.7) * 0.92 + t * 0.08); }
    function yWait(t: number) { return yBase - (yBase - yTop) * t * 0.10; }
    function pathFor(fy: (t: number) => number, t: number) {
      var d = '', steps = 60;
      for (var i = 0; i <= steps * t; i++) {
        var p = i / steps;
        var x = x0 + (x1 - x0) * p;
        d += (i === 0 ? 'M' : 'L') + x.toFixed(1) + ' ' + fy(p).toFixed(1);
      }
      return d || 'M' + x0 + ' ' + yBase;
    }
    var lineWait = el('path', { 'class': 'wv-line-wait', d: pathFor(yWait, 1) });
    var lineAI = el('path', { 'class': 'wv-line-ai', d: pathFor(yAI, 0) });
    var gapLine = el('line', { 'class': 'wv-gap', x1: x1, y1: yBase, x2: x1, y2: yBase }) as SVGLineElement;
    var halo = el('circle', { 'class': 'wv-dot-halo', r: 9, cx: x0, cy: yBase });
    var dot = el('circle', { 'class': 'wv-dot', r: 2.5, cx: x0, cy: yBase });
    var tAI = el('text', { 'class': 'wv-t-ai', x: x0, y: yBase, 'text-anchor': 'start' });
    tAI.textContent = 'with AI';
    var tWait = el('text', { 'class': 'wv-t-wait', x: x1 + 8, y: yWait(1) + 3 });
    tWait.textContent = 'waiting';
    var tGap = el('text', { 'class': 'wv-t-gap', x: x1 + 8, y: (yAI(1) + yWait(1)) / 2 + 3 }) as SVGTextElement;
    tGap.textContent = 'the gap';
    var tT0 = el('text', { 'class': 'wv-t-axis', x: x0, y: H - 6 });
    tT0.textContent = 'today';
    var tT1 = el('text', { 'class': 'wv-t-axis', x: x1, y: H - 6, 'text-anchor': 'end' });
    tT1.textContent = '+12 months';
    var axis = el('line', { x1: x0, y1: yBase + 10, x2: x1, y2: yBase + 10, stroke: 'rgba(255,255,255,0.12)', 'stroke-width': 1 });
    [axis, lineWait, gapLine, lineAI, halo, dot, tWait, tGap, tAI, tT0, tT1].forEach(function (n) { svg.appendChild(n); });
    host.appendChild(svg);

    function render(t: number) {
      lineAI.setAttribute('d', pathFor(yAI, t));
      var x = x0 + (x1 - x0) * t, y = yAI(t);
      dot.setAttribute('cx', String(x)); dot.setAttribute('cy', String(y));
      halo.setAttribute('cx', String(x)); halo.setAttribute('cy', String(y));
      if (x > x1 - 60) {
        tAI.setAttribute('text-anchor', 'end');
        tAI.setAttribute('x', String(x - 10));
      } else {
        tAI.setAttribute('text-anchor', 'start');
        tAI.setAttribute('x', String(x + 10));
      }
      tAI.setAttribute('y', String(Math.max(y - 10, yTop + 4)));
      gapLine.setAttribute('x1', String(x)); gapLine.setAttribute('x2', String(x));
      gapLine.setAttribute('y1', String(y)); gapLine.setAttribute('y2', String(yWait(t)));
      var gapVisible = t > 0.3;
      gapLine.style.opacity = gapVisible ? '1' : '0';
      tGap.style.opacity = t > 0.85 ? '1' : '0';
      tGap.style.transition = 'opacity .6s ease';
      gapLine.style.transition = 'opacity .6s ease';
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) { render(1); return; }

    var DRAW = 7000;
    var raf: number | null = null;
    function ease(p: number) { return p < 0.5 ? 2 * p * p : 1 - Math.pow(-2 * p + 2, 2) / 2; }
    function play() {
      if (raf) cancelAnimationFrame(raf);
      var start: number | null = null;
      function frame(ts: number) {
        if (start === null) start = ts;
        var p = Math.min((ts - start) / DRAW, 1);
        render(ease(p));
        if (p < 1) raf = requestAnimationFrame(frame);
      }
      raf = requestAnimationFrame(frame);
    }
    render(0);
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        if (en.isIntersecting) { play(); }
        else { if (raf) cancelAnimationFrame(raf); render(0); }
      });
    }, { threshold: 0.35 });
    io.observe(host);
  })();
</script>

<script>
  // CTA form → Formspree (same live endpoint as cut one).
  const FORM_ENDPOINT = 'https://formspree.io/f/xeedlwnw';
  const form = document.getElementById('cta-email-form') as HTMLFormElement | null;
  const container = document.getElementById('cta-form');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailInput = form.querySelector('input[name="email"]') as HTMLInputElement;
    const button = form.querySelector('button') as HTMLButtonElement;
    const email = emailInput.value.trim();
    if (!email) return;

    button.disabled = true;
    button.textContent = 'Sending…';

    try {
      const res = await fetch(FORM_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ email, source: 'Website CTA' }),
      });
      if (!res.ok) throw new Error('Request failed');
      container!.innerHTML =
        '<div class="cta-success">' +
        '<div class="cs-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>' +
        "<h3>We'll be in touch.</h3>" +
        '<p>Thanks for reaching out. Joel will be in touch within one business day to set up a time.</p>' +
        '</div>';
    } catch {
      button.disabled = false;
      button.textContent = "Let's talk";
      let err = container!.querySelector('.cta-error');
      if (!err) {
        err = document.createElement('p');
        err.className = 'cta-note cta-error';
        err.innerHTML =
          'Something went wrong sending that. Please try again, or email <a href="mailto:joel@localai.nz" style="text-decoration:underline;text-underline-offset:3px;">joel@localai.nz</a> directly.';
        form.insertAdjacentElement('afterend', err);
      }
    }
  });
</script>
